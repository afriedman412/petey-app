    type: string
  Line 1b (e) Cost (or other basis):
    type: string
  Line 1b (g) Adjustments to gain or loss:
    type: string
  Line 1b (h) Gain or (loss):
    type: string
  Line 2 (d) Proceeds (sales price):
    type: string
  Line 2 (e) Cost (or other basis):
    type: string
  Line 2 (g) Adjustments to gain or loss:
    type: string
  Line 2 (h) Gain or (loss):
    type: string
  Line 3 (d) Proceeds (sales price):
    type: string
  Line 3 (e) Cost (or other basis):
    type: string
  Line 3 (g) Adjustments to gain or loss:
    type: string
  Line 3 (h) Gain or (loss):
    type: string
  Line 4 — Short-term gain from Form 6252 and short-term gain or (loss) from Forms 4684, 6781, and 8824:
    type: string
  Line 5 — Net short-term gain or (loss) from partnerships, S corporations, estates, and trusts (Schedule(s) K-1):
    type: string
  Line 6 — Short-term capital loss carryover:
    type: string
  Line 7 — Net short-term capital gain or (loss):
    type: string
