name: irs_1040_schedule_d
record_type: object
description: Capital gains and losses schedule for Form 1040.
source:
  owner: IRS
  url: https://www.irs.gov/forms-pubs/about-schedule-d-form-1040
fields:
  Name(s) shown on return:
    type: string
  Social security number:
    type: string
  Disposed of investment in qualified opportunity fund — Yes:
    type: bool
  Disposed of investment in qualified opportunity fund — No:
    type: bool
  Line 1a (d) Proceeds (sales price):
    type: string
  Line 1a (e) Cost (or other basis):
    type: string
  Line 1a (g) Adjustments to gain or loss:
    type: string
  Line 1a (h) Gain or (loss):
    type: string
