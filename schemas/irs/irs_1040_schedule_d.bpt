    type: string
  Line 8a (e) Cost (or other basis):
    type: string
  Line 8a (g) Adjustments to gain or loss:
    type: string
  Line 8a (h) Gain or (loss):
    type: string
  Line 8b (d) Proceeds (sales price):
    type: string
  Line 8b (e) Cost (or other basis):
    type: string
  Line 8b (g) Adjustments to gain or loss:
    type: string
  Line 8b (h) Gain or (loss):
    type: string
  Line 9 (d) Proceeds (sales price):
    type: string
  Line 9 (e) Cost (or other basis):
    type: string
  Line 9 (g) Adjustments to gain or loss:
    type: string
  Line 9 (h) Gain or (loss):
    type: string
